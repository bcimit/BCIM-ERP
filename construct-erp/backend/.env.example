# ============================================
# ConstructERP India — Backend Environment
# ============================================

# Server
NODE_ENV=development
PORT=5000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=construct_erp
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m
SESSION_MAX_HOURS=8

# File Upload (AWS S3 or local)
UPLOAD_PROVIDER=local
UPLOAD_PATH=./uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=ap-south-1

# GST / TDS Config
DEFAULT_GST_RATE=18
TDS_194C_COMPANY=2
TDS_194C_INDIVIDUAL=1

# WhatsApp — Twilio
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Sandbox number (testing): whatsapp:+14155238886
# Production: your approved WhatsApp Business number e.g. +919XXXXXXXXX
TWILIO_WHATSAPP_FROM=+14155238886
# Comma-separated admin numbers to notify (include country code, no spaces)
WHATSAPP_ADMIN_NUMBERS=+919XXXXXXXXX,+919XXXXXXXXX

# Email — Microsoft Graph API (recommended, reuses OneDrive Azure AD app)
# Step 1: Go to Azure Portal → App registrations → your app → API permissions
# Step 2: Add permission → Microsoft Graph → Application permissions → Mail.Send
# Step 3: Click "Grant admin consent"
# Step 4: Set MAIL_FROM to the mailbox the app will send FROM
MAIL_FROM=admin@yourdomain.onmicrosoft.com
# Optional separate app for mail (leave blank to reuse ONEDRIVE_* credentials)
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# Email — SMTP fallback (only used if Graph is not configured)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password

# MRS workflow email notifications
MRS_STORES_NOTIFY_EMAILS=vijayan@bcim.in
MRS_PROCUREMENT_NOTIFY_EMAILS=bkmanjunath@bcim.in,praveen@bcim.in

# pg_dump path for automated backups
# Linux/Docker: leave unset (uses pg_dump from PATH)
# Windows: PG_DUMP_PATH=C:\Program Files\PostgreSQL\18\bin\pg_dump.exe
# PG_DUMP_PATH=

# Backup directory (Docker: set to /app/backups — mapped to a named volume)
# BACKUP_DIR=/app/backups

# Log directory (Docker: set to /app/logs — mapped to a named volume)
# LOG_DIR=/app/logs

# Frontend URL (for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# AI Copilot (Bill Tracker pilot) — Anthropic Claude
ANTHROPIC_API_KEY=
BCIM_COPILOT_MODEL=claude-haiku-4-5-20251001
BCIM_COPILOT_MAX_TOKENS=2048
