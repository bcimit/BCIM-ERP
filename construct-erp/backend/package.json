{
  "name": "construct-erp-backend",
  "version": "1.0.0",
  "description": "Construction ERP Backend - India (Node.js + Express + PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npm install --prefix ../frontend && npm run build --prefix ../frontend",
    "backup": "node scripts/run-backup.js",
    "migrate": "node src/config/migrate.js",
    "seed": "node src/config/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "mssql": "^12.5.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "uuid": "^9.0.1",
