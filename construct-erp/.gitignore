# ── Secrets — NEVER commit these ─────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
*.crt
*.p12

# ── Deployment secrets ────────────────────────────────────────
nginx/ssl/
backups/
certbot_certs/

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
*.err
tmp_*.png
eng.traineddata

# ── React build output ────────────────────────────────────────
# NOTE: frontend/build/ is intentionally TRACKED, not ignored. The backend
# serves the SPA from this committed folder (server.js express.static), and
# Railway's own frontend build step is unreliable — so the committed build is
# the real deploy artifact. Rebuild (`npm run build`) and commit build/ when
# shipping frontend changes. Do NOT re-add `frontend/build/` here.
frontend/dist/

# ── Backend ───────────────────────────────────────────────────
backend/logs/
backend/uploads/

# ── Docker volumes (local dev) ────────────────────────────────
postgres_data/
redis_data/

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
frontend/android/
frontend/node_modules/
.claude/

# ── Bulk RA-bill engineering data (CAD/BBS/RFI dumps — never commit) ──
WDIRY0151/
*.dwg
