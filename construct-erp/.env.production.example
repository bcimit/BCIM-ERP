# .env.production.example
# Copy to .env.production and fill in ALL values before deploying
# NEVER commit .env.production to git

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=app.bcim.in

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_MIN_20_CHARS
DB_HOST=postgres
DB_PORT=5432
DB_NAME=construct_erp
DB_USER=erp_user

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING
JWT_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://app.bcim.in

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_PROVIDER=local
# For Hetzner Object Storage (S3-compatible), switch to:
# UPLOAD_PROVIDER=s3
# S3_ENDPOINT=https://fsn1.your-objectstorage.com
# S3_BUCKET=constructerp-uploads
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_REGION=eu-central

# ── India Tax Defaults ────────────────────────────────────────────────────────
DEFAULT_GST_RATE=18
TDS_194C_COMPANY=2
TDS_194C_INDIVIDUAL=1

# ── Email (optional — for notifications) ─────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@bcim.in
# SMTP_PASS=your_app_password

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/app/backups
