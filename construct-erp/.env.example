# ============================================================
# ConstructERP — Environment Variables
# Copy to .env and fill in real values. Never commit .env!
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=construct_erp
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_64_char_random_string_in_production
JWT_REFRESH_SECRET=another_64_char_random_string_for_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_PROVIDER=local
# UPLOAD_PROVIDER=onedrive   # set to onedrive to store files in OneDrive

# ── OneDrive (optional — only if UPLOAD_PROVIDER=onedrive) ───
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_REDIRECT_URI=
ONEDRIVE_FOLDER_ID=

# ── Frontend build arg (used by docker-compose) ───────────────
API_URL=http://localhost/api/v1
