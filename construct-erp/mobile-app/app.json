{
  "expo": {
    "name": "BCIM ERP",
    "slug": "bcim-erp-mobile",
    "scheme": "bcimerp",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0f2d64",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.bcim.erp"
    },
    "android": {
      "package": "in.bcim.erp",
      "adaptiveIcon": {
        "backgroundColor": "#0f2d64"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "apiBaseUrl": "http://bcim.ddns.net:3001/api/v1",
      "loginPageUrl": "http://bcim.ddns.net:3000"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BCIM ERP to scan asset QR labels."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0f2d64",
          "androidMode": "default",
          "androidCollapsedTitle": "BCIM ERP"
        }
      ]
    ]
  }
}
